'''
MONTHLY BUDGET REPORT AUTOMATION:
This will automatically "write data" with Python from a Database report to a budget Excel file.
This example concept can be applied to a daily, monthly, quarterly, or yearly report.
'''

#Add the following excel locations:
data=r'C:\Users\scott\OneDrive\Desktop\Excel\JuneDataAdmin.xlsx'
admin=r'C:\Users\scott\OneDrive\Desktop\Excel\278000 ADMIN FY21.xlsx' 
month='June' #What month?


#CHANGE NOTHING BELOW:
import csv, time
from openpyxl import load_workbook
import pandas as pd
from pandas import ExcelWriter
from pandas import ExcelFile
from datetime import date

#Program starts, no need to change anything below:
print("Writing report on: ", date.today().strftime("%m-%d-%Y") )
start=time.time()

#DATA REPORT:
data = pd.read_excel(data) 
data = pd.DataFrame(data, columns=['GL Account', ' Monthly Debits', ' Monthly Credits']) #turns dataframe into tuple
data['Ending'] = data.apply(lambda x: x[' Monthly Debits'] - x[' Monthly Credits'], axis = 1)  
head=data.columns #Index(['GL Account', ' Monthly Debits', ' Monthly Credits', 'Ending'], dtype='object')
data['GL Account'] = data.apply(lambda x: x['GL Account'][19:25], axis = 1).astype(int)


#ACCESS REPORT:
wb = load_workbook(admin)
ws = wb["Monthly Budget Report"].values #keeps forumulas
df = pd.DataFrame(ws)
df.columns = df.iloc[0] 

# MANIPULATE DATA, ADD NEW MONTH:
for d in data['GL Account']:
    for account in df['Account']:
        if str(d)==str(account):
            i = data[data['GL Account']==int(account)].index[0]
            amount=data['Ending'].iloc[i]
            #print(i, account, amount)

            index = df[df['Account']==int(account)].index[0] 
            df.at[int(index), month]=amount
            #print(index, month, amount, account)
        
#CREATE NEW BUDGET SHEET:
df = df.iloc[1: , :] #delete duplicate column header
try:
    newFile=r'C:\Users\scott\OneDrive\Desktop\Excel\createdMO'+month+'.xlsx'
    writer = ExcelWriter(newFile)
    df.to_excel(writer,'Sheet1', index=False)
    print("created new budget excel sheet called: ", newFile)
    writer.save()
except:
    print("error happened creating new budget excel file", newFile)
print("Program Finished! ", round(time.time()-start, 3), " seconds")



