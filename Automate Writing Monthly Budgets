import pandas as pd
from pandas import ExcelWriter
from pandas import ExcelFile
import numpy as np

file=r'C:\Users\scott\OneDrive\Desktop\Excel\write.xlsx'
newFile=r'C:\Users\scott\OneDrive\Desktop\Excel\writerNEW.xlsx'
month='July'

july={0: "1.21", 2: "12.76", 4: "39.45"}

wb = load_workbook(file)
sheet_name = wb.get_sheet_names()[0]
ws = wb[sheet_name]
df = pd.DataFrame(ws.values)
df.columns = df.iloc[0] #Index(['Account id', 'May', 'June', 'July', None], dtype='object', name=0)
#colInd=df.columns.get_loc(month)
colInd='July'

for j in july:
    amount=july[j]
    df.at[j+1, colInd]=float(amount)
print(df)
    
writer = ExcelWriter(newFile)
df.to_excel(writer,'Sheet1', index=False, columns=None, header=False)
writer.save()

print("check new file: ", newFile)
