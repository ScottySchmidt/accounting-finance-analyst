'''
This will compare around 2000 accounting transactions between Datatel (real money) and Access (accounting records);
A large majority of them should equal most of the time (there will be new postings in Datatel);
Thus, this is important because not every transaction needs to be rechecked weekly.
Some transactions may not have had a transaction yet, but this helps find the ones that are already balanced.
In additon, section 2 will help decide which transactions should have a "D" added in REQ column 
A D in REQ column means the real money has had a transaction via Datatel.
'''

import csv, time
import pandas as pd
from datetime import date

print("Running Access to Datatel report on: ", date.today() )
start=time.time()

access=r'C:\Users\scott\OneDrive\Desktop\AccessFY22.xlsx'
datatel=r'C:\Users\scott\OneDrive\Desktop\DatatelFY22.xlsx'

#Opens Access Excel sheet:
accessDF=pd.read_excel(access) #Access DataFrame
accessDF=accessDF.filter(['ACCOUNT ID', 'INVOICE AMOUNT', 'REQ#']) #Only need these 3 columns
accessSubtotals = accessDF.groupby('ACCOUNT ID')['INVOICE AMOUNT'].sum().reset_index() #Sum totals by account number

#Opens Datatel Excel Sheet:
dataDF=pd.read_excel(datatel).fillna(0) #Datatel Dataframe
dataDF['Ending Amount'] = dataDF.apply(lambda x: x[' YTD Debits'] - x[' YTD Credits'], axis = 1)
dataDF=dataDF.filter(['GL Account', 'Ending Amount'])
dataList=dataDF.to_dict(orient='list')

dataSubtotals=dataDF.groupby('GL Account')['Ending Amount'].sum().reset_index()
dataSubtotals['GL Account'] = dataSubtotals['GL Account'].str.replace('-', '') #gets rid of Hyphens 
    
for d in dataSubtotals['GL Account']: #checks each account in Datatel...
    for a in accessSubtotals['ACCOUNT ID']: # checks each account in Access...
        if d==a: #if Datatel and Access Account are the same then do the following:
            dRow=dataSubtotals.loc[dataSubtotals['GL Account']==d]
            aRow=accessSubtotals.loc[accessSubtotals['ACCOUNT ID']==a]
            dSUM=round(float(dRow['Ending Amount'].values), 2) #datatel Subtotal Number
            aSUM=round(float(aRow['INVOICE AMOUNT'].values),2) #access Subtotal Number
            if  dSUM==aSUM: # if Datatel and Access numbers equal do the following:
                print(dSUM, " datatel matches access total: ", aSUM, d, " Account ID ", a)
                continue; #Nothing else is needed, accounts are balanced
            else: # Datatel and Access account subtotal does NOT equal:
                # They do NOT match and further checking will be done by printing the below info:
                hyphens=a[0:5]+"-"+a[5:7]+"-"+a[7:16]+"-"+a[16:] #adds hyphens to account number, easier to copy/paste
                print(a, " Access-----check account----- Datatel", hyphens)
                #print(dSUM, " datatel DOES NOT match access ", aSUM, ". Difference is: ", round(float(dSUM-aSUM), 2) 
print("Finished matching datatel to access accounts in: ", round(time.time()-start, 3), " seconds");
print("----------END SECTION1 ---------- \n")

'''
SECTION 2: Check for Missing D in Req Column;
When something gets posted in Datatel, Access must be updated with a D;
Normally, this takes a great deal of time (10 hours a week) by having to check EVERY individual account;
When a new transaction with real money pulls, a D is required in REQ# column in Access.
'''

print("----- START SECTION2; Checking for Missing Ds in REQ Column ----- ")
