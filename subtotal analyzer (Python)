#Find all possible combos: 
from itertools import combinations
import time
start=time.time()

input = [1, 3, 66, 90, 5, 5  ]
findNum=100

output = sum([list(map(list, combinations(input, i))) for i in range(len(input) + 1)], [])

i=0;
while (i< len(output)):
    #print(output[i]) 
    total=sum(output[i]) 
    if total==findNum:
        print("Found------")
        print(output[i], total)
        print("Found Total------")
    i=i+1
end=time.time()
print("Done.", end-start, "seconds" )  



